{
  "package": "configuration-contracts",
  "version": "1.0.0",
  "dependsOn": {"domain-types": "^1.0.0", "rule-contracts": "^1.0.0"},
  "vocabularies": {
    "componentKinds": ["schema", "mapping", "rule", "workflow", "view", "template"],
    "lifecycle": ["draft", "tested", "approved", "active", "superseded", "retired"]
  },
  "contracts": {
    "Workflow": {"required": ["id", "version", "states", "transitions"], "optional": []},
    "View": {"required": ["id", "version", "role", "fields"], "optional": []},
    "Template": {"required": ["id", "version", "mediaType", "contentHash"], "optional": []},
    "ConfigurationBundle": {"required": ["id", "version", "lifecycle", "scope", "schemas", "mappings", "rules", "workflow", "views", "templates"], "optional": ["testEvidence", "approval", "predecessor", "rollbackTarget"]}
  },
  "activationRule": "Only an approved bundle with immutable test evidence may become active; runtime application is prospective."
}
