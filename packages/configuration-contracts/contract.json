{
  "package": "configuration-contracts",
  "version": "1.1.0",
  "dependsOn": {"domain-types": "^1.0.0", "rule-contracts": "^1.0.0"},
  "vocabularies": {
    "componentKinds": {"python": "ComponentKind", "typescript": "ComponentKind", "constant": "COMPONENT_KINDS", "values": ["schema", "mapping", "rule", "workflow", "view", "template"]},
    "lifecycle": {"values": ["draft", "tested", "approved", "active", "superseded", "retired"]}
  },
  "contracts": {
    "WorkflowTransition": {"model": "WorkflowTransition", "fields": [
      {"name": "fromState", "type": "InvoiceLifecycle", "required": true},
      {"name": "toState", "type": "InvoiceLifecycle", "required": true},
      {"name": "action", "type": "Action", "required": true},
      {"name": "role", "type": "Role", "required": true}
    ]},
    "Workflow": {"model": "WorkflowContract", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true, "minimum": 1},
      {"name": "states", "type": "InvoiceLifecycle[]", "required": true},
      {"name": "transitions", "type": "WorkflowTransition[]", "required": true}
    ]},
    "View": {"model": "ViewContract", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true, "minimum": 1},
      {"name": "role", "type": "Role", "required": true},
      {"name": "fields", "type": "string[]", "required": true}
    ]},
    "Template": {"model": "TemplateContract", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true, "minimum": 1},
      {"name": "mediaType", "type": "string", "required": true},
      {"name": "contentHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "parameters", "type": "map<string,any>", "required": false}
    ]},
    "ExtractionComponentVersion": {"model": "ExtractionComponentVersionContract", "fields": [
      {"name": "sourceArtifact", "type": "VersionReference", "required": true},
      {"name": "rawResponseArtifact", "type": "VersionReference", "required": false, "nullable": true},
      {"name": "provider", "type": "string", "required": true},
      {"name": "model", "type": "string", "required": true},
      {"name": "promptVersion", "type": "string", "required": true},
      {"name": "parserVersion", "type": "string", "required": true},
      {"name": "schemaVersion", "type": "string", "required": true}
    ]},
    "ValidationInputManifest": {"model": "ValidationInputManifestContract", "fields": [
      {"name": "schemaVersion", "type": "string", "required": true},
      {"name": "engineVersion", "type": "string", "required": true},
      {"name": "normalizedInputs", "type": "map<string,any>", "required": true},
      {"name": "invoiceSnapshot", "type": "VersionReference", "required": true},
      {"name": "artifacts", "type": "VersionReference[]", "required": true},
      {"name": "schemas", "type": "VersionReference[]", "required": true},
      {"name": "mappings", "type": "VersionReference[]", "required": true},
      {"name": "rules", "type": "RuleDefinition[]", "required": true},
      {"name": "workflow", "type": "WorkflowContract", "required": true},
      {"name": "views", "type": "ViewContract[]", "required": true},
      {"name": "templates", "type": "TemplateContract[]", "required": true},
      {"name": "configurationVersion", "type": "VersionReference", "required": true},
      {"name": "extractionComponents", "type": "ExtractionComponentVersionContract[]", "required": true}
    ]},
    "PackageFileDigest": {"model": "PackageFileDigestContract", "fields": [
      {"name": "path", "type": "string", "required": true},
      {"name": "sha256", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "byteSize", "type": "integer", "required": true, "minimum": 0}
    ]},
    "PackageBuildInput": {"model": "PackageBuildInputContract", "fields": [
      {"name": "schemaVersion", "type": "string", "required": true},
      {"name": "packageId", "type": "string", "required": true},
      {"name": "invoiceSnapshot", "type": "VersionReference", "required": true},
      {"name": "attestationId", "type": "string", "required": true},
      {"name": "validationRun", "type": "VersionReference", "required": true},
      {"name": "validationInputManifestId", "type": "string", "required": true},
      {"name": "validationInputManifestHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "configurationVersion", "type": "VersionReference", "required": true},
      {"name": "template", "type": "TemplateContract", "required": true},
      {"name": "invoicePayload", "type": "map<string,any>", "required": true},
      {"name": "validationSummary", "type": "map<string,any>", "required": true},
      {"name": "claims", "type": "map<string,any>[]", "required": true},
      {"name": "evidence", "type": "VersionReference[]", "required": true}
    ]},
    "PackageReproductionManifest": {"model": "PackageReproductionManifestContract", "fields": [
      {"name": "schemaVersion", "type": "string", "required": true},
      {"name": "buildInputHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "packageManifestHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "archiveSha256", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "archiveByteSize", "type": "integer", "required": true, "minimum": 0},
      {"name": "files", "type": "PackageFileDigestContract[]", "required": true},
      {"name": "template", "type": "TemplateContract", "required": true},
      {"name": "validationInputManifestId", "type": "string", "required": true},
      {"name": "validationInputManifestHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "invoiceSnapshot", "type": "VersionReference", "required": true}
    ]},
    "ConfigurationBundle": {"model": "ConfigurationBundleContract", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true, "minimum": 1},
      {"name": "lifecycle", "type": "ConfigurationLifecycle", "required": true},
      {"name": "scope", "type": "map<string,string>", "required": true},
      {"name": "schemas", "type": "VersionReference[]", "required": true},
      {"name": "mappings", "type": "VersionReference[]", "required": true},
      {"name": "rules", "type": "RuleDefinition[]", "required": true},
      {"name": "workflow", "type": "WorkflowContract", "required": true},
      {"name": "views", "type": "ViewContract[]", "required": true},
      {"name": "templates", "type": "TemplateContract[]", "required": true},
      {"name": "testEvidence", "type": "VersionReference", "required": false, "nullable": true},
      {"name": "approval", "type": "ActorReference", "required": false, "nullable": true},
      {"name": "predecessor", "type": "VersionReference", "required": false, "nullable": true},
      {"name": "rollbackTarget", "type": "VersionReference", "required": false, "nullable": true}
    ]},
    "ConfigurationLifecycleEventDto": {"model": "ConfigurationLifecycleEventDto", "fields": [
      {"name": "state", "type": "ConfigurationLifecycle", "required": true},
      {"name": "action", "type": "Action", "required": true},
      {"name": "actorId", "type": "string", "required": true},
      {"name": "actorRole", "type": "Role", "required": true},
      {"name": "actorOrganizationId", "type": "string", "required": true},
      {"name": "rationale", "type": "string", "required": true},
      {"name": "testEvidenceId", "type": "string", "required": true, "nullable": true},
      {"name": "approvalId", "type": "string", "required": true, "nullable": true},
      {"name": "predecessorVersionId", "type": "string", "required": true, "nullable": true},
      {"name": "successorVersionId", "type": "string", "required": true, "nullable": true},
      {"name": "rollbackTargetVersionId", "type": "string", "required": true, "nullable": true},
      {"name": "eventHash", "type": "string", "required": true, "pattern": "^[a-f0-9]{64}$"},
      {"name": "occurredAt", "type": "datetime", "required": true}
    ]},
    "GovernedConfigurationVersionDto": {"model": "GovernedConfigurationVersionDto", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true, "minimum": 1},
      {"name": "configuration", "type": "map<string,any>", "required": true},
      {"name": "state", "type": "ConfigurationLifecycle", "required": true},
      {"name": "active", "type": "boolean", "required": true},
      {"name": "history", "type": "ConfigurationLifecycleEventDto[]", "required": true}
    ]},
    "ConfigurationLifecycleResponseDto": {"model": "ConfigurationLifecycleResponseDto", "fields": [
      {"name": "versions", "type": "GovernedConfigurationVersionDto[]", "required": true}
    ]},
    "ActiveConfigurationDto": {"model": "ActiveConfigurationDto", "fields": [
      {"name": "id", "type": "string", "required": true},
      {"name": "version", "type": "integer", "required": true},
      {"name": "activatedAt", "type": "string", "required": true}
    ]}
  },
  "activationRule": "Only an approved bundle with immutable test evidence may become active; runtime application is prospective."
}
